@using WebAppBackend.Models
@model DeleteAssetViewModel

@{
    ViewData["Title"] = "Delete Asset";
}

<section class="container my-4">
    <div class="card shadow-sm border-danger">
        <div class="card-header bg-danger text-white">
            <h2 class="mb-0">Delete Confirmation</h2>
        </div>
        <div class="p-4">
            <h3 class="mb-4 card-header-pills border-danger border-bottom border-1">
                Are you sure you want to delete <strong>@Model.Asset.Name</strong>?
            </h3>

            <div class="mb-4 text-center">
                @switch (Model.Asset.Type)
                {
                    case AssetType.Image:
                        <img src="@Url.Content(Model.Asset.FileUrl)" class="img-fluid rounded border" style="max-height: 400px;" alt="Preview of @Model.Asset.Name" loading="lazy" />
                        break;

                    case AssetType.Video:
                        <video controls class="w-100 rounded border" style="max-height: 400px;" aria-label="Video preview of @Model.Asset.Name">
                            <source src="@Url.Content(Model.Asset.FileUrl)" type="video/mp4" />
                            Your browser does not support the video tag.
                        </video>
                        break;

                    case AssetType.Audio:
                        <audio controls class="w-100 mt-3" aria-label="Audio preview of @Model.Asset.Name">
                            <source src="@Url.Content(Model.Asset.FileUrl)" type="audio/mpeg" />
                            Your browser does not support the audio element.
                        </audio>
                        break;
                    case AssetType.Document:
                        @if (Model.Asset.FileUrl.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase))
                        {
                            <iframe src="@Url.Content(Model.Asset.FileUrl)"
                                    class="w-100 border rounded"
                                    style="height:700px;">
                            </iframe>

                            <a href="@Url.Content(Model.Asset.FileUrl)"
                               target="_blank"
                               class="btn btn-primary">
                                Open Document
                            </a>

                            <a href="@Url.Content(Model.Asset.FileUrl)"
                               download
                               class="btn btn-secondary">
                                Download
                            </a>
                        }
                        break;

                    case AssetType.Text:
                        <div class="w-100 border rounded"
                             style="height:700px;">

                            <p class="border rounded p-3 bg-light">
                                @Model.TextContent
                            </p>

                            <a href="@Url.Content(Model.Asset.FileUrl)"
                               target="_blank"
                               class="btn btn-primary">
                                Open Text File
                            </a>

                            <a href="@Url.Content(Model.Asset.FileUrl)"
                               download
                               class="btn btn-secondary">
                                Download
                            </a>
                        </div>
                        break;

                    default:
                        <p class="text-muted"><em>No preview available for this file type.</em></p>
                        break;
                }
            </div>

            <dl class="row">
                <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Asset.Name)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(m => m.Asset.Name)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Asset.Description)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(m => m.Asset.Description)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Asset.Author)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(m => m.Asset.Author)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Asset.Location)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(m => m.Asset.Location)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Asset.Date)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(m => m.Asset.Date)</dd>

                <dt class="col-sm-3">Categories</dt>
                <dd class="col-sm-9">
                    @if (Model.Asset.Categories != null && Model.Asset.Categories.Any())
                    {
                        <ul class="list-unstyled mb-0">
                            @foreach (var cat in Model.Asset.Categories)
                            {
                                <li class="list-inline-item">
                                    <span class="badge badge-secondary">@cat.Name</span>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted mb-0">No categories assigned.</p>
                    }
                </dd>
            </dl>
        </div>

        <div class="card-footer d-flex justify-content-between">
            <form asp-controller="Asset" asp-action="Delete" method="post" class="mb-0">
                <input type="hidden" asp-for="Asset.Id" />
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash mr-1"></i>Delete
                </button>
            </form>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </div>
</section>
