{
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:__PORT__"
      }
    }
  },
  "BasePath": "__API_BASE_PATH__",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedOrigins": [
    "https://staging.__DOMAIN__",
    "https://www.staging.__DOMAIN__"
  ]
}
